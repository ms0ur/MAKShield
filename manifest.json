{
  "manifest_version": 2,
  "name": "MAKShield",
  "version": "0.2.4",
  "description": "E2E Encryption for MAX Messenger (WEB). All encryption happens locally - no data is collected or transmitted to external servers.",
  "author": "ms0ur",
  "homepage_url": "https://github.com/ms0ur/MakShield",
  "browser_specific_settings": {
    "gecko": {
      "id": "makshield@ms0ur",
      "strict_min_version": "57.0"
    }
  },
  "permissions": [
    "storage",
    "https://web.max.ru/*"
  ],
  "web_accessible_resources": [
    "maksicon.png",
    "maksbanner.png"
  ],
  "content_scripts": [
    {
      "matches": ["https://web.max.ru/*"],
      "js": [
        "presets.js",
        "crypto.js",
        "storage.js",
        "scanner.js",
        "sender.js",
        "ui.js",
        "main.js"
      ],
      "run_at": "document_end"
    }
  ]
}