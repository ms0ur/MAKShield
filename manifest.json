{
  "manifest_version": 3,
  "name": "MAKShield",
  "version": "0.3.0",
  "description": "E2E Encryption for MAX & VK Messengers (WEB). All encryption happens locally - no data is collected or transmitted to external servers.",
  "author": "ms0ur",
  "homepage_url": "https://github.com/ms0ur/MakShield",
  "browser_specific_settings": {
    "gecko": {
      "id": "makshield@ms0ur",
      "strict_min_version": "109.0"
    },
    "gecko_android": {
      "strict_min_version": "120.0"
    }
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://web.max.ru/*",
    "https://vk.com/*",
    "https://vk.ru/*",
    "https://m.vk.com/*",
    "https://m.vk.ru/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["maksicon.png", "maksbanner.png", "selectors.json"],
      "matches": ["https://web.max.ru/*", "https://vk.com/*", "https://vk.ru/*", "https://m.vk.com/*", "https://m.vk.ru/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://web.max.ru/*", "https://vk.com/*", "https://vk.ru/*", "https://m.vk.com/*", "https://m.vk.ru/*"],
      "js": [
        "presets.js",
        "crypto.js",
        "storage.js",
        "scanner.js",
        "sender.js",
        "ui.js",
        "main.js"
      ],
      "run_at": "document_end"
    }
  ]
}